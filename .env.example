# === Kiro / Ollama-compatible LLM ===
OLLAMA_API_KEY=your_kiro_api_key_here
OLLAMA_BASE_URL=https://your-kiro-endpoint/v1
OLLAMA_MODEL=claude-opus-4-7

# === Tavily web search ===
# Free 1000 query/month: https://tavily.com
TAVILY_API_KEY=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

# === Site (CORS allowlist) ===
SITE_URL=http://localhost:5173

# === Server ===
PORT=3000

# === Database (Neon Postgres + pgvector) ===
# Buat di https://neon.tech → connection string lengkap
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# === Embedding ===
# Dimensi embedding (HARUS match dengan model embedding Anda)
# bge-m3 = 1024, text-embedding-3-small = 1536, text-embedding-3-large = 3072
EMBED_DIM=1024
EMBED_MODEL=bge-m3

# === Auth ===
# Password yang user input di halaman login. Kosongkan = no auth (publik).
ACCESS_PASSWORD=ganti_password_kuat
# Secret untuk HMAC sign cookie. WAJIB di prod, generate random:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=ganti_dengan_random_64_char
