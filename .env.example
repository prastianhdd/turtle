# === Kiro / Ollama-compatible LLM ===
OLLAMA_API_KEY=your_kiro_api_key_here
OLLAMA_BASE_URL=https://your-kiro-endpoint/v1
OLLAMA_MODEL=claude-opus-4-7

# === Tavily web search ===
# Free 1000 query/month: https://tavily.com
TAVILY_API_KEY=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

# === Site (CORS allowlist) ===
SITE_URL=http://localhost:5173

# === Server ===
PORT=3000

# === Storage ===
# Lokasi simpan image upload di disk VPS. Default ./data/files (dev) atau /var/turtle/files (prod).
STORAGE_DIR=/var/turtle/files

# === Auth (Google OAuth) ===
# Buat di https://console.cloud.google.com → OAuth credentials
# Authorized redirect URI: https://your-domain/api/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REDIRECT_URI=https://claudepro.web.id/api/auth/google/callback

# Secret untuk HMAC sign JWT. WAJIB random 32+ byte di prod.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=ganti_dengan_random_64_char_hex

# Optional: set "true" untuk skip auth (dev/local). Jangan di prod.
# AUTH_DISABLED=false

# === Database (Neon Postgres + pgvector) ===
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
EMBED_DIM=1024
EMBED_MODEL=bge-m3

# === Auth ===
# Password yang user input di halaman login. Kosongkan = no auth (publik).
ACCESS_PASSWORD=ganti_password_kuat
# Secret untuk HMAC sign cookie. WAJIB di prod, generate random:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=ganti_dengan_random_64_char
